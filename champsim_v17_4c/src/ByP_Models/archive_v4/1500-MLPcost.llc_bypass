#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// MODEL 1500 — MLPcost — LLC

inline bool llc_bypass_init_1500[NUM_CPUS] = {};

#define SHALL_LLC_BYPASS_DEFINED
inline void llc_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (llc_bypass_init_1500[cpu]) return;
    cout << "LLC Bypass [1500-MLPcost]: low overlap + high kappa" << endl;
    llc_bypass_init_1500[cpu] = true;
}

inline bool llc_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    llc_bypass_initialize(cpu, L1D, L2C, LLC);

    auto& bws = lpm[cpu][LPM_LLC].bkt[BKT_WS];
    uint64_t omega = bws.ω_activeMemCy();
    if (omega == 0) return false;

    double overlap_frac = (double)bws.cy[CY_X] / (double)omega;
    if (overlap_frac > 0.25) return false;

    double kap = bws.κ_pureMissFracOfMissCy();
    return (kap > 0.40);
}
