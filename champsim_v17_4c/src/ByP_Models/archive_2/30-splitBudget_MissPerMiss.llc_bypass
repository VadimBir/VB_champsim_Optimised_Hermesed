#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// MODEL 30 (Claude): SPLIT BUDGET — miss-denominated at both levels
// LLC: no next MSHR — available = camat_per_miss_LLC only (freeing own slot)
// upper gate: L2C must be full
// bypass iff camat_per_miss_LLC > immediate + future + entry (all camat_LLC units)

inline bool llc_bypass_init[NUM_CPUS] = {};

#define SHALL_LLC_BYPASS_DEFINED
inline void llc_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (llc_bypass_init[cpu]) return;
        cout << "LLC Bypass [30 Split Budget miss-per-miss]:\n"
             << "  avail = camat_per_miss_LLC  (no next MSHR)\n"
             << "  gate: LLC full AND L2C full\n";
    llc_bypass_init[cpu] = true;
}

inline bool llc_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    llc_bypass_initialize(cpu, L1D, L2C, LLC);

    if (LLC->MSHR.occupancy < LLC->MSHR.SIZE) return false;
    if (L2C->MSHR.occupancy < L2C->MSHR.SIZE) return false;

    uint32_t free = LLC->MSHR.SIZE - LLC->MSHR.occupancy;
    if (free == 0) return false;

    double camat = lpm[cpu][LLC_type].gm.camat_activeMemCyDivAccesses;
    double h3 = lpm[cpu][LLC_type].g.h_pureHitCy; double m3 = lpm[cpu][LLC_type].g.m_pureMissCy;
    if (m3 < 1.0) m3 = 1.0;
    double cpm = camat * (h3 + m3) / m3;

    double lpmr_l2c = lpm[cpu][L2C_type].gm.lpmr_activeMemCyDivIdealCy;
    double lpmr_llc = lpm[cpu][LLC_type].gm.lpmr_activeMemCyDivIdealCy;
    if (lpmr_l2c < 0.001) lpmr_l2c = 0.001;
    if (lpmr_llc < 0.001) lpmr_llc = 0.001;

    double available = cpm;  // freeing own slot — no next MSHR to fill
    double immediate = (double)(LLC->RQ.occupancy + LLC->PQ.occupancy) * camat;
    double future    = (lpmr_llc / lpmr_l2c) * camat;
    double entry     = camat;

    return available > (immediate + future + entry);
}
