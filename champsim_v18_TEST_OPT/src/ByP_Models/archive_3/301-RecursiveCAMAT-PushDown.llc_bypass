#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// ============================================================
// MODEL 301 — RecursiveCAMAT-PushDown (LLC level)
// Paper: Liu et al. JCST 36(1) 2021, eq. 41–42, Section 6
//
// Explicit C-AMAT push-down at LLC (base case):
//   MSHR_LLC == 0: no active LLC misses → this miss would be lone
//   → pure miss period at LLC guaranteed (mirrors model 201).
//   Bypassing to DRAM eliminates the m(LLC) term entirely.
//   No "B" condition: DRAM has no equivalent of GR — it accepts
//   all requests without MSHR saturation in the bypass model.
//
// This is the terminal condition of the push-down chain:
//   L1 push-down requires L2 miss-starved (model 301 L1).
//   L2 push-down requires LLC miss-starved (model 301 L2).
//   LLC push-down requires LLC itself to be lone (no next level).
//   The three levels form a self-consistent hierarchy.
// ============================================================

inline bool llc_bypass_init[NUM_CPUS] = {};

#define SHALL_LLC_BYPASS_DEFINED
inline void llc_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (llc_bypass_init[cpu]) return;
    cout << "LLC Bypass [301-RecursiveCAMAT-PushDown]:\n"
         << "  bypass iff MSHR_LLC==0\n"
         << "  lone LLC miss: no active misses → pure-miss period guaranteed (eq 18/33)\n"
         << "  terminal case of push-down chain: DRAM accepts all bypassed requests" << endl;
    llc_bypass_init[cpu] = true;
}

inline bool llc_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    llc_bypass_initialize(cpu, L1D, L2C, LLC);
    // MSHR==0: no active LLC misses → new miss is lone → pure miss period starts
    return (LLC->MSHR.occupancy == 0);
}
