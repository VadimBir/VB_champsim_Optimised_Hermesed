#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// MODEL 565 — Kappa+Phi+Latency at L2, 1-tab debug indent
// Gate 1: κ_short(L2) > κ_long(L2)
// Gate 2: φ(L2) > 1 - this_H_L2/C-AMAT(LLC)
// Gate 3: κ_short(L2)*this_H_L2 < κ_short(LLC)*H_LLC

static constexpr double this_H_L2  = 10.0;
static constexpr double H_LLC = 50.0;

#define DBG_565 1
#define DBG_CNT_PRINT 100

inline bool l2_bypass_init_565[NUM_CPUS] = {};
inline uint64_t l2_dbg_counter_565[NUM_CPUS] = {};

#define SHALL_L2C_BYPASS_DEFINED
inline void l2c_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (l2_bypass_init_565[cpu]) return;
    cout << "L2 Bypass [565-KappaPhiLatency]: G1=k_short>k_long G2=phi>1-H/camat_nxt G3=k*H(l)<k*H(l+1)" << endl;
    l2_bypass_init_565[cpu] = true;
}

inline bool l2c_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    l2c_bypass_initialize(cpu, L1D, L2C, LLC);

    double this_k_s_l2    = get_kappa_short(cpu, LPM_L2C);
    double this_k_l_l2    = get_kappa_long(cpu, LPM_L2C);
    double this_phi_l2    = get_phi_short(cpu, LPM_L2C);
    double this_camat_l2  = lpm[cpu][LPM_L2C].wsm.camat_activeMemCyDivAccesses;
    double camat_llc = lpm[cpu][LPM_LLC].wsm.camat_activeMemCyDivAccesses;
    double k_s_llc   = get_kappa_short(cpu, LPM_LLC);
    double phi_llc   = get_phi_short(cpu, LPM_LLC);

    bool g1 = (this_k_l_l2 >= 1e-6) && (this_k_s_l2 > this_k_l_l2);
    bool g2 = (camat_llc >= this_H_L2) && (this_phi_l2 > 1.0 - this_H_L2 / camat_llc);
    bool g3 = (this_k_s_l2 * this_H_L2) < (k_s_llc * H_LLC);
    bool byp = g1 && g2 && g3;

#if DBG_565
    if ((++l2_dbg_counter_565[cpu] & DBG_CNT_PRINT) == 0) {
        printf("  [565-L2] k_s=%.3f k_l=%.3f phi=%.3f camat=%.2f | camat_LLC=%.2f k_s_LLC=%.3f phi_LLC=%.3f"
               " | G1=%d G2=%d G3=%d -> %s\n",
               this_k_s_l2, this_k_l_l2, this_phi_l2, this_camat_l2,
               camat_llc, k_s_llc, phi_llc,
               g1, g2, g3, byp ? "BYP" : "---");
    }
#endif

    return byp;
}
