#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// MODEL 880 — MSHRtimingL2 at L2
// 880-MSHRtimingL2 L2: dynamic lat_ratio from observed miss latency

#define DBG_880 1

inline bool l2_bypass_init_880[NUM_CPUS] = {};
inline uint64_t l2_dbg_counter_880[NUM_CPUS] = {};

#define SHALL_L2C_BYPASS_DEFINED
inline void l2c_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (l2_bypass_init_880[cpu]) return;
    cout << "L2 Bypass [880-MSHRtimingL2]: 880-MSHRtimingL2 L2: dynamic lat_ratio from observed miss latency" << endl;
    l2_bypass_init_880[cpu] = true;
}

inline bool l2c_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    l2c_bypass_initialize(cpu, L1D, L2C, LLC);

double camat_this = lpm[cpu][LPM_L2C].wsm.camat_activeMemCyDivAccesses;
    double camat_next = lpm[cpu][LPM_LLC].wsm.camat_activeMemCyDivAccesses;
    double cpa_this   = lpm[cpu][LPM_L2C].wsm.cpa_totalCyDivAccesses;
    double cpa_next   = lpm[cpu][LPM_LLC].wsm.cpa_totalCyDivAccesses;
    if (camat_next < 1e-6 || cpa_next < 1e-6) { bool byp = false; return byp; }
    uint64_t w_next = lpm[cpu][LPM_LLC].ws.ω_activeMemCy();
    double mu_kappa_next = w_next ? (double)lpm[cpu][LPM_LLC].ws.m_pureMissCy / w_next : 0.0;
    double l2_hr   = 1.0 - mu_kappa_next;
    int    l1_free = L2C->MSHR.SIZE - L2C->MSHR.occupancy;
    int    l2_free = LLC->MSHR.SIZE - LLC->MSHR.occupancy;
    double bias    = (l2_free * l2_hr) / (l1_free + 1.0);
    if (bias < 0.2) bias = 0.2;
    if (bias > 5.0) bias = 5.0;
    double l2c_total_miss = (double)(L2C->sim_miss[cpu][0] + 1);
    double llc_total_miss = (double)(LLC->sim_miss[cpu][0] + 1);
    double l2c_avg_lat = (double)L2C->total_miss_latency / l2c_total_miss;
    double llc_avg_lat = (double)LLC->total_miss_latency / llc_total_miss;
    if (l2c_avg_lat < 1.0 || llc_avg_lat < 1.0) { bool byp = false; return byp; }
    double lat_ratio = l2c_avg_lat / llc_avg_lat;
    bool byp = (camat_this * cpa_this) / (camat_next * cpa_next) < lat_ratio * bias;

#if DBG_880
    if ((++l2_dbg_counter_880[cpu] & 0xFFFF) == 0) {
        printf("  [880-L2] -> %s\n", byp ? "BYP" : "---");
    }
#endif

    return byp;
}
