#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// MODEL 611DBG — CamatCPAbias_phi_dbg at L2
// camat(t)*cpa(t)/camat(n)*cpa(n)*bias<LAT(t)/LAT(n) + phi gate: phi(t) < phi(n)*K
// phi gate is fully dynamic: K=4.0, threshold scales with LLC health

#define DBG_611DBG_L2 0

inline bool l2_bypass_init_611DBG[NUM_CPUS] = {};
inline uint64_t l2_dbg_counter_611DBG[NUM_CPUS] = {};
inline double l2_acc_camat_this_611[NUM_CPUS] = {};
inline double l2_acc_camat_next_611[NUM_CPUS] = {};
inline double l2_acc_cpa_this_611[NUM_CPUS]   = {};
inline double l2_acc_cpa_next_611[NUM_CPUS]   = {};
inline double l2_acc_bias_611[NUM_CPUS]       = {};
inline double l2_acc_lhs_611[NUM_CPUS]        = {};
inline double l2_acc_phi_this_611[NUM_CPUS]   = {};
inline double l2_acc_phi_next_611[NUM_CPUS]   = {};
inline int    l2_acc_byp_611[NUM_CPUS]        = {};
inline int    l2_acc_phi_blocked_611[NUM_CPUS]= {};

#define SHALL_L2C_BYPASS_DEFINED
inline void l2c_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (l2_bypass_init_611DBG[cpu]) return;
    cout << "L2 Bypass [611DBG-CamatCPAbias_phi_dbg]: camat*cpa ratio + dynamic phi gate (phi_L2 < phi_LLC*4.0)" << endl;
    l2_bypass_init_611DBG[cpu] = true;
}

inline bool l2c_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    l2c_bypass_initialize(cpu, L1D, L2C, LLC);

    double camat_this = lpm[cpu][LPM_L2C].wsm.camat_activeMemCyDivAccesses;
    double camat_next = lpm[cpu][LPM_LLC].wsm.camat_activeMemCyDivAccesses;
    double cpa_this   = lpm[cpu][LPM_L2C].wsm.cpa_totalCyDivAccesses;
    double cpa_next   = lpm[cpu][LPM_LLC].wsm.cpa_totalCyDivAccesses;
    if (camat_next < 1e-6 || cpa_next < 1e-6) { return false; }

    uint64_t w_next = lpm[cpu][LPM_LLC].ws.ω_activeMemCy();
    double mu_kappa_next = w_next ? (double)lpm[cpu][LPM_LLC].ws.m_pureMissCy / w_next : 0.0;
    double l2_hr   = 1.0 - mu_kappa_next;
    int    l1_free = L2C->MSHR.SIZE - L2C->MSHR.occupancy;
    int    l2_free = LLC->MSHR.SIZE - LLC->MSHR.occupancy;
    double bias    = (l2_free * l2_hr) / (l1_free + 1.0);
    if (bias < 0.2) bias = 0.2;
    if (bias > 5.0) bias = 5.0;

    double lat_ratio  = (double)L2C->LATENCY / (double)LLC->LATENCY;
    double lhs        = (camat_this * cpa_this) / (camat_next * cpa_next);
    bool   camat_ok   = lhs < lat_ratio * bias;

    double phi_this   = get_phi_short(cpu, LPM_L2C);
    double phi_next   = get_phi_short(cpu, LPM_LLC);
    bool   phi_ok     = (phi_next < 1e-6) ? false : (phi_this < phi_next * 4.0);

    bool byp = camat_ok && phi_ok;

    l2_acc_camat_this_611[cpu] += camat_this;
    l2_acc_camat_next_611[cpu] += camat_next;
    l2_acc_cpa_this_611[cpu]   += cpa_this;
    l2_acc_cpa_next_611[cpu]   += cpa_next;
    l2_acc_bias_611[cpu]       += bias;
    l2_acc_lhs_611[cpu]        += lhs;
    l2_acc_phi_this_611[cpu]   += phi_this;
    l2_acc_phi_next_611[cpu]   += phi_next;
    l2_acc_byp_611[cpu]        += byp ? 1 : 0;
    l2_acc_phi_blocked_611[cpu]+= (camat_ok && !phi_ok) ? 1 : 0;

    if (++l2_dbg_counter_611DBG[cpu] % 10000 == 0) {
        printf("  [611DBG-L2] camat=%.2f/%.2f cpa=%.1f/%.1f bias=%.2f lhs=%.3f thr*bias=%.3f phi=%.3f/%.3f phi_thr=%.3f byp%%=%d phi_blk=%d\n",
               l2_acc_camat_this_611[cpu]/10000, l2_acc_camat_next_611[cpu]/10000,
               l2_acc_cpa_this_611[cpu]/10000,   l2_acc_cpa_next_611[cpu]/10000,
               l2_acc_bias_611[cpu]/10000,       l2_acc_lhs_611[cpu]/10000,
               lat_ratio * (l2_acc_bias_611[cpu]/10000),
               l2_acc_phi_this_611[cpu]/10000,   l2_acc_phi_next_611[cpu]/10000,
               (l2_acc_phi_next_611[cpu]/10000) * 4.0,
               l2_acc_byp_611[cpu], l2_acc_phi_blocked_611[cpu]);
        l2_acc_camat_this_611[cpu] = l2_acc_camat_next_611[cpu] = 0;
        l2_acc_cpa_this_611[cpu]   = l2_acc_cpa_next_611[cpu]   = 0;
        l2_acc_bias_611[cpu]       = l2_acc_lhs_611[cpu]        = 0;
        l2_acc_phi_this_611[cpu]   = l2_acc_phi_next_611[cpu]   = 0;
        l2_acc_byp_611[cpu]        = l2_acc_phi_blocked_611[cpu]= 0;
    }

    return byp;
}
