#include "cache.h"
#include "lpm_tracker.h"

#ifndef L1D_type
#define L1D_type  4
#define L2C_type  5
#define LLC_type  6
#endif

// MODEL B-successor — L2
// 520a base + enhancements:
//   Gate 0: kappa_short < 0.05 pre-filter
//   Gate 1: kappa degradation
//   Gate 2: W2D-averaged LLC pressure, neutral threshold (cap 1.0, same as 520a)

inline bool l2_bypass_init_Bsucc[NUM_CPUS] = {};

#define SHALL_L2C_BYPASS_DEFINED
inline void l2c_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    if (l2_bypass_init_Bsucc[cpu]) return;
    cout << "L2 Bypass [B-successor]:\n"
         << "  Gate0: k_short >= 0.05 | Gate1: k_short > k_long | Gate2: k_reduce >= W2D pressure" << endl;
    l2_bypass_init_Bsucc[cpu] = true;
}

inline bool l2c_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
    l2c_bypass_initialize(cpu, L1D, L2C, LLC);

    /* ── Gate 0: pre-filter ── */
    double k_now = get_kappa_short(cpu, LPM_L2C);
    if (k_now < 0.05) return false;

    /* ── Gate 1: kappa degradation ── */
    double k_long = get_kappa_long(cpu, LPM_L2C);
    if (k_long < 1e-6) return false;
    if (k_now <= k_long) return false;

    /* ── Gate 2: W2D-averaged next-level pressure ── */
    double llc_camat = lpm[cpu][LPM_LLC].met[MET_W2D].camat_activeMemCyDivAccesses;
    double llc_cpa   = lpm[cpu][LPM_LLC].met[MET_W2D].cpa_totalCyDivAccesses;
    if (llc_cpa < 1.0) return false;

    double next_pressure = llc_camat / llc_cpa;
    if (next_pressure > 1.0) next_pressure = 1.0;

    double k_reduce_pct = k_now / k_long;
    return (k_reduce_pct >= next_pressure);
}
