#include "cache.h"
#include "lpm_tracker.h"
#ifndef L1D_type
#define L1D_type 4
#define L2C_type 5
#define LLC_type 6
#endif
inline bool l2_bypass_init_2202[NUM_CPUS] = {};
#define SHALL_L2C_BYPASS_DEFINED
inline void l2c_bypass_initialize(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
 if (l2_bypass_init_2202[cpu]) return;
 printf("L2 Bypass [2202-kappa_rising_phi_falling_pressure]\n");
 l2_bypass_init_2202[cpu] = true;
}
inline bool l2c_bypass_operate(int cpu, CACHE *L1D, CACHE *L2C, CACHE *LLC) {
 l2c_bypass_initialize(cpu, L1D, L2C, LLC);
 double k_s = get_kappa_short(cpu, LPM_L2C);
 double k_l = get_kappa_long(cpu, LPM_L2C);
 if (k_s <= k_l) return false;
 double p_s = get_phi_short(cpu, LPM_L2C);
 double p_l = get_phi_long(cpu, LPM_L2C);
 if (p_s >= p_l) return false;
 double llc_camat = lpm[cpu][LPM_LLC].met[MET_WL].camat_activeMemCyDivAccesses;
 double llc_cpa   = lpm[cpu][LPM_LLC].met[MET_WL].cpa_totalCyDivAccesses;
 if (llc_cpa < 1.0) return false;
 double pressure = llc_camat / llc_cpa;
 if (pressure > 1.0) pressure = 1.0;
 double headroom = 1.0 - pressure;
 double k_ratio = k_s / k_l;
 return (k_ratio < headroom);
}
